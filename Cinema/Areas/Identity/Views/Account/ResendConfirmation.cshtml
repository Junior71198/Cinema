@model Cinema.ModelView.ResendConfirmationVM

@{
    ViewData["Title"] = "ResendConfirmation";
}

<h1>Resend Confirmation</h1>


<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="ResendConfirmation">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="UserNameOrEmail" class="control-label"></label>
                <input asp-for="UserNameOrEmail" class="form-control" />
                <span asp-validation-for="UserNameOrEmail" class="text-danger"></span>
            </div>

        
            <div class="form-group">
                <input type="submit" value="Resend Confirmation" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Login">Login</a>
</div>
