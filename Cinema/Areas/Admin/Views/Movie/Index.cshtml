@model MovieVM

<div class="d-flex justify-content-between align-items-center mb-3">

    <!-- Create Button -->
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus me-1"></i> Create Movie
    </a>

    <!-- Filter Button -->
    <button class="btn btn-outline-secondary" type="button"
            data-bs-toggle="collapse"
            data-bs-target="#filterSection">
        <i class="fas fa-filter me-1"></i> Filter
    </button>

</div>

<!-- Filter Section -->
<div class="collapse mb-4" id="filterSection">
    <div class="card card-body">

        <form >

            <div class="row g-3">

                <div class="col-md-4">
                    <label for="name" class="form-label">Movie Name</label>
                    <input type="text" name="MovieName" class="form-control"
                           placeholder="Search by name..." value="@ViewBag.MovieName" />
                </div>

                <div class="col-md-4">
                    <label for="minPrice" class="form-label">Min Price</label>
                    <input type="number" name="MinPrice" class="form-control"
                           placeholder="Min price..." value="@ViewBag.MinPrice" />
                </div>

                <div class="col-md-4">
                    <label for="maxPrice" class="form-label">Max Price</label>
                    <input type="number" name="MaxPrice" class="form-control"
                           placeholder="Max price..." value="@ViewBag.MaxPrice" />
                </div>
                <div class="col-md-4">
                    <label for="CategoryId" class="form-label">Category</label>
                    <select name="CategoryId" class="form-control">
                        <option value="0">All Categories</option>
                        @if (ViewData["Categories"] is IEnumerable<Category> categories)
                            {
                                
                            @foreach (var item in categories)
                        {
                            <option value="@item.Id">
                                @item.Name
                            </option>
                        }
                            }
                    </select>
                </div>
                <div class="col-md-4">
                    <label for="CinemaId" class="form-label">Cinema</label>
                    <select name="CinemaId" class="form-control">
                        <option value="0">All Cinemas</option>
                        @if (ViewData["Cenemas"] is IEnumerable<Cenema> cinemas)
                            {
                                
                            @foreach (var item in cinemas)
                        {
                            <option value="@item.Id">
                                @item.Name
                            </option>
                        }
                            }
                    </select>
                </div>
                

                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-success w-100">
                         Apply Filter
                    </button>
                </div>

            </div>

        </form>
    </div>
</div>

<div class="table-responsive scrollbar">
    <table class="table table-bordered overflow-hidden align-middle">

        <thead class="table-light">
            <tr>
                <th>Name</th>
                
                <th>Price</th>
                <th>Discount</th>
                <th>Category Name</th>
                <th>Cinema Name</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model.Movies)
            {
                <tr>
                    <td>@item.Name</td>

                    
                    <td>@item.Price</td>
                    <td>@item.Discount</td>
                    <td>@item.Category.Name</td>
                    <td>@item.Cinema.Name</td>

                    <td>
                        @if (item.Status)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Inactive</span>
                        }
                    </td>

                    <td class="text-end">
                        <div class="dropdown">
                            <button class="btn btn-link text-dark btn-sm dropdown-toggle"
                                    type="button"
                                    data-bs-toggle="dropdown">
                                <i class="fas fa-ellipsis-h"></i>
                            </button>

                            <div class="dropdown-menu dropdown-menu-end">
                                <a class="dropdown-item" href="/Admin/Movie/Edit/@item.Id">Edit</a>
                                <a class="dropdown-item text-danger" href="/Admin/Movie/Delete/@item.Id">Delete</a>
                            </div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>

    </table>
</div>