@model CreateMovieVM 

<div>
<body>

            <form class="p-4 p-md-5" method="post" enctype="multipart/form-data">
               
                <div class="mb-3">
                    <div class="mb-4">
                    <label for="MovieName" class="form-label fw-semibold">Movie Name</label>
                    <input type="text"
                           class="form-control form-control-lg"
                           id="MovieName"
                           name="Name"
                           placeholder="Enter Movie name"
                           value="@Model.Movie.Name"
                           required>
                </div>
                
                <div class="mb-3">
                    <label for="name" class="form-label">Main Image</label>
                    <input type="file" class="form-control" name="ImageFile"  accept="image/*"  onchange="previewImage(event)">
                    <span class="text-danger" asp-validation-for="ImageFile"></span>

                </div>
                <div class="mb-3">
                    <label for="name" class="form-label">Sub Images</label>
                    <input type="file" class="form-control" name="SubImageFiles" accept="image/*" multiple onchange="previewImage(event)"/>
                   <span class="text-danger" asp-validation-for="SubImageFiles"></span>

                </div>

                <div class="mb-4">
                    <label for="description" class="form-label fw-semibold">Description</label>
                    <textarea class="form-control"
                              id="description"
                              name="Description"
                              rows="5"
                              placeholder="Write a short description">@Model.Movie.Description</textarea>
                </div>
                 <div class="mb-4">
                    <label for="Price" class="form-label fw-semibold">Price</label>
                    <input type="number"
                           class="form-control form-control-lg"
                           id="Price"
                           name="Price"
                           placeholder="Enter Price"
                           value="@Model.Movie.Price"
                           required>
                </div> 
                <div class="mb-4">
                    <label for="Discount" class="form-label fw-semibold">Discount</label>
                    <input type="number"
                           class="form-control form-control-lg"
                           id="Discount"
                           name="Discount"
                           placeholder="Enter Discount"
                            value="@Model.Movie.Discount"
                           required>
                </div>

              <div class="mb-3">
                    <label for="CategoryId class="form-label">Category</label>
                    <select name="CategoryId" class="form-select">
                       @foreach (var item in Model.Categories)
                        {
                            @if(item.Id == Model.Movie.CategoryId)
                            {
                                <option value="@item.Id" selected>@item.Name</option>
                            }
                            else
                            {
                                <option value="@item.Id">@item.Name</option>     
                            }
                        }
                  
                    </select>
                </div>
                <div class="mb-3">
                    <label for="CinemaId class="form-label">Cinema</label>
                    <select name="CinemaId" class="form-select">
                       @foreach (var item in Model.Cenemas)
                        {
                            @if(item.Id == Model.Movie.CinemaId)
                            {
                                <option value="@item.Id" selected>@item.Name</option>
                            }
                            else
                            {
                                <option value="@item.Id">@item.Name</option>     
                            }
                        }
                  
                    </select>
                </div>

                <div class="mb-4">
                    <label for="status" class="form-label fw-semibold">Status</label>
                    <select class="form-select form-select-lg" id="status" name="Status" required>
                      @if (Model.Status)
                        {
                            <option value="True" selected>Active</option>
                            <option value="False">InActive</option>
                        }
                        else
                        {
                            <option value="True" >Active</option>
                            <option value="False" selected>InActive</option>
                        }
                    </select>
                </div>

                <div class="d-flex flex-column flex-sm-row gap-2 justify-content-end pt-2">
                   
                    <button type="submit" class="btn btn-success px-4">Edit Movie</button>
                </div>
            </form>
        </section>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script>
</body>
</div>